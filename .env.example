# Copy to .env and fill in before `docker compose up`.

# Postgres superuser password (compose-internal).
POSTGRES_PASSWORD=change-me

# Protects every family's encryption keys. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Losing this makes all stored data unrecoverable; changing it locks out
# existing families.
EXHALE_MASTER_SECRET=change-me

# 1 = every family endpoint requires a login token (recommended).
EXHALE_REQUIRE_AUTH=1

# 1 = signups need an invite code (a family's own code to join it, or the
# bootstrap code below to start a new family). Recommended for any hosted
# deployment that isn't open to the public.
EXHALE_INVITE_ONLY=0
# The operator's code for minting new families under invite-only. Generate:
#   python3 -c "import secrets; print(secrets.token_urlsafe(12))"
EXHALE_BOOTSTRAP_INVITE=

# Requests per client IP per minute on the auth/OAuth endpoints (0 = off).
EXHALE_RATE_LIMIT_PER_MINUTE=60

# Outbound 🔴 critical-alert emails (each alert sent exactly once; a family
# opts in by setting a notify address in the app). Unset host = alerts off.
EXHALE_SMTP_HOST=
EXHALE_SMTP_PORT=587
EXHALE_SMTP_USER=
EXHALE_SMTP_PASSWORD=
EXHALE_SMTP_FROM=
EXHALE_SMTP_TLS=1

# Background auto-sync: re-pull each family's connected sources every N minutes
# (Gmail + remembered calendar/ics syncs). Unset/0 = off.
EXHALE_AUTO_SYNC_MINUTES=

# Where browsers reach the API (baked into the web bundle at build time).
# For phone/LAN access use e.g. http://192.168.1.20:8000 and rebuild web.
EXHALE_PUBLIC_API_URL=http://localhost:8000

# Optional — live Gmail ingestion (Google Cloud OAuth credentials).
# Either a short-lived access token:
EXHALE_GMAIL_ACCESS_TOKEN=
# ...or the long-lived refresh trio:
EXHALE_GMAIL_REFRESH_TOKEN=
EXHALE_GMAIL_CLIENT_ID=
EXHALE_GMAIL_CLIENT_SECRET=

# Optional — live Google Calendar (caregiver availability for the Care-Coverage
# Engine). Either a short-lived access token, or the long-lived refresh trio.
EXHALE_GCAL_ACCESS_TOKEN=
EXHALE_GCAL_REFRESH_TOKEN=
EXHALE_GCAL_CLIENT_ID=
EXHALE_GCAL_CLIENT_SECRET=

# Optional — "Connect Google" OAuth app (ONE registration, all users). Register
# once in the Google Cloud console; every family then connects with one click.
# The redirect URI must match what you registered (…/v1/oauth/google/callback).
EXHALE_GOOGLE_CLIENT_ID=
EXHALE_GOOGLE_CLIENT_SECRET=
EXHALE_GOOGLE_REDIRECT_URI=

# Optional — "Connect Outlook" OAuth app (Microsoft identity platform / Azure).
# One app registration; redirect URI ends in …/v1/oauth/microsoft/callback.
EXHALE_MSFT_CLIENT_ID=
EXHALE_MSFT_CLIENT_SECRET=
EXHALE_MSFT_REDIRECT_URI=

# Optional — LLM-backed extraction (Claude reads the emails the rule engine
# can't). Set the flag to 1 and provide an Anthropic API key.
EXHALE_LLM_EXTRACTOR=0
ANTHROPIC_API_KEY=
# Model override (default claude-opus-4-8):
EXHALE_LLM_MODEL=
# Vision extraction (photos/screenshots) reuses ANTHROPIC_API_KEY above.
# Model override (default claude-opus-4-8):
EXHALE_VISION_MODEL=
